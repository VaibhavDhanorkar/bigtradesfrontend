{
  "name": "bigtrades-monorepo",
  "private": true,
  "scripts": {
    "dev": "npm run dev --prefix frontend/BigTrades-frontend",
    "dev:frontend": "npm run dev --prefix frontend/BigTrades-frontend",
    "dev:backend": "cd backend/BigTrades-backend && uvicorn main:app --reload --port 3001",
    "dev:all": "concurrently \"npm run dev:backend\" \"npm run dev\"",
    "build": "npm run build --prefix frontend/BigTrades-frontend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
